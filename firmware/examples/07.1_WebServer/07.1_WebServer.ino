void Process_linearSpeed_slider(){
  String speed = server.arg("VALUE");

  // conver the string sent from the web page to an int
  linearSpeed = speed.toFloat();
  Serial.print("Update linear speed: "); Serial.println(linearSpeed);
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}

void Process_angularSpeed_slider(){
  String speed = server.arg("VALUE");

  // conver the string sent from the web page to an int
  angularSpeed = speed.toFloat();
  Serial.print("Update angular speed: "); Serial.println(angularSpeed);
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}

void Process_stop(){
  linear = 0.0;
  angular = 0.0;
  Serial.println("STOP");
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}

void Process_forward(){
  linear = linearSpeed;
  angular = 0.0;
  Serial.println("FORWARD");
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}

void Process_backward(){
  linear = -linearSpeed;
  angular = 0.0;
  Serial.println("BACKWARD");
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}

void Process_left(){
  linear = 0.0;
  angular = angularSpeed;
  Serial.println("LEFT");
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}

void Process_right(){
  linear = 0.0;
  angular = -angularSpeed;
  Serial.println("RIGTH");
  server.send(200, "text/plain", ""); //Send empty response to web page to keep it alive
}