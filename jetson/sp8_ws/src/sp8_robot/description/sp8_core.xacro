<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>

    <!-- BASE FOOTPRINT LINK-->

    <link name="base_footprint_link">
        
    </link>

    <!-- BASE LINK -->

    <joint name="base_link_join" type="fixed">
        <parent link="base_footprint_link"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 0.052"/> <!-- 0.052-->
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0.0 0.0 0.036"/>
            <geometry>
                <cylinder radius="0.125" length="0.1"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.036"/>
            <geometry>
                <cylinder radius="0.125" length="0.1"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "3.0" length = "0.1" radius = "0.125">
            <origin xyz="0.0 0.0 0.036" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="base_link">
        <material>Gazebo/White</material>
    </gazebo>

    <!-- LEFT WHEEL LINK -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0.0 0.08 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
        
    </joint>

    <link name="left_wheel_link">
        <visual>
            <origin rpy= "1.5707 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.053" length="0.005"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin rpy= "1.5707 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.053" length="0.005"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass = "0.01" length = "0.005" radius = "0.053">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel_link">
        <material>Gazebo/Black</material>
        <mu1 value="1.0"/>
        <mu2 value="1.0"/>
    </gazebo>

    <!-- RIGHT WHEEL LINK -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0.0 -0.08 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
        
    </joint>

    <link name="right_wheel_link">
        <visual>
            <origin rpy= "1.5707 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.053" length="0.005"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin rpy= "1.5707 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.053" length="0.005"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.01" length = "0.005" radius = "0.053">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel_link">
        <material>Gazebo/Black</material>
        <mu1 value="1.0"/>
        <mu2 value="1.0"/>
    </gazebo>

    <!-- FRONT CASTER LINK -->

    <joint name="front_caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_caster_link"/>
        <origin xyz= "0.08 0.0 0.0"/>
    </joint>

    <link name="front_caster_link">
        <visual>
            <origin xyz="0.0 0.0 -0.01"/> <!--0.26-->
            <geometry>
                <cylinder radius="0.0125" length="0.052"/>
            </geometry>
            <material name="black"/>
        </visual> 
        <collision>
            <origin xyz="0.0 0.0 -0.026"/>
            <geometry>
                <cylinder radius="0.0125" length="0.052"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.01" length = "0.052" radius = "0.0125">
            <origin xyz="0.0 0.0 -0.026" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>       
    </link>

    <gazebo reference="front_caster_link">
        <material>Gazebo/Black</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>

    <!-- BACK CASTER LINK -->

    <joint name="back_caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="back_caster_link"/>
        <origin xyz= "-0.08 0.0 0.0"/>
    </joint>

    <link name="back_caster_link">
        <visual>
            <origin xyz="0.0 0.0 -0.01"/> <!--0.26-->
            <geometry>
                <cylinder radius="0.025" length="0.052"/>
            </geometry>
            <material name="white"/>
        </visual> 
        <collision>
            <origin xyz="0.0 0.0 -0.026"/>
            <geometry>
                <cylinder radius="0.025" length="0.052"/>
            </geometry>
        </collision> 
        <xacro:inertial_cylinder mass = "0.01" length = "0.052" radius = "0.025">
            <origin xyz="0.0 0.0 -0.026" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>        
    </link>

    <gazebo reference="back_caster_link">
        <material>Gazebo/White</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>

</robot>